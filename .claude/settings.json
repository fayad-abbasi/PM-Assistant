{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-frontmatter.sh \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-crosslinks.sh \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "jira": {
      "command": "uv",
      "args": ["run", "--directory", "mcp-servers/jira-server", "python", "server.py"],
      "env": {
        "JIRA_BASE_URL": "${JIRA_BASE_URL}",
        "JIRA_EMAIL": "${JIRA_EMAIL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
      }
    },
    "miro": {
      "command": "uv",
      "args": ["run", "--directory", "mcp-servers/miro-server", "python", "server.py"],
      "env": {
        "MIRO_ACCESS_TOKEN": "${MIRO_ACCESS_TOKEN}"
      }
    },
    "lucid": {
      "command": "uv",
      "args": ["run", "--directory", "mcp-servers/lucid-server", "python", "server.py"],
      "env": {
        "LUCID_API_TOKEN": "${LUCID_API_TOKEN}"
      }
    },
    "figma": {
      "command": "uv",
      "args": ["run", "--directory", "mcp-servers/figma-server", "python", "server.py"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
      }
    },
    "slack": {
      "command": "uv",
      "args": ["run", "--directory", "mcp-servers/slack-server", "python", "server.py"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_USER_TOKEN": "${SLACK_USER_TOKEN}"
      }
    }
  }
}
